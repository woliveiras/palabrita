{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Build Debug",
			"type": "shell",
			"command": "./gradlew :app:assembleDebug",
			"options": {
				"cwd": "${workspaceFolder}"
			},
			"group": {
				"kind": "build",
				"isDefault": true
			},
			"problemMatcher": []
		},
		{
			"label": "Build Release",
			"type": "shell",
			"command": "./gradlew :app:assembleRelease",
			"options": {
				"cwd": "${workspaceFolder}"
			},
			"group": "build",
			"problemMatcher": []
		},
		{
			"label": "Install Debug",
			"type": "shell",
			"command": "./gradlew :app:installDebug",
			"options": {
				"cwd": "${workspaceFolder}"
			},
			"group": "build",
			"problemMatcher": []
		},
		{
			"label": "Run App",
			"type": "shell",
			"command": "./gradlew :app:installDebug && adb shell am start -n com.woliveiras.palabrita/.MainActivity",
			"options": {
				"cwd": "${workspaceFolder}"
			},
			"group": "build",
			"problemMatcher": []
		},
		{
			"label": "Clean",
			"type": "shell",
			"command": "./gradlew clean",
			"options": {
				"cwd": "${workspaceFolder}"
			},
			"problemMatcher": []
		},
		{
			"label": "Unit Tests",
			"type": "shell",
			"command": "./gradlew test",
			"options": {
				"cwd": "${workspaceFolder}"
			},
			"group": {
				"kind": "test",
				"isDefault": true
			},
			"problemMatcher": []
		},
		{
			"label": "Instrumented Tests",
			"type": "shell",
			"command": "./gradlew connectedAndroidTest",
			"options": {
				"cwd": "${workspaceFolder}"
			},
			"group": "test",
			"problemMatcher": []
		},
		{
			"label": "Check Formatting",
			"type": "shell",
			"command": "./gradlew spotlessCheck",
			"options": {
				"cwd": "${workspaceFolder}"
			},
			"problemMatcher": []
		},
		{
			"label": "Fix Formatting",
			"type": "shell",
			"command": "./gradlew spotlessApply",
			"options": {
				"cwd": "${workspaceFolder}"
			},
			"problemMatcher": []
		},
		{
			"label": "Start Emulator",
			"type": "shell",
			"command": "emulator -avd Pixel_7_API_34",
			"isBackground": true,
			"problemMatcher": {
				"pattern": {
					"regexp": "^.*$",
					"file": 1,
					"location": 2,
					"message": 3
				},
				"background": {
					"activeOnStart": true,
					"beginsPattern": "^.*Android Virtual Device.*",
					"endsPattern": "^.*boot completed.*"
				}
			}
		},
		{
			"label": "ADB Logcat (Palabrita)",
			"type": "shell",
			"command": "adb logcat --pid=$(adb shell pidof com.woliveiras.palabrita) 2>/dev/null || adb logcat | grep -i palabrita",
			"options": {
				"cwd": "${workspaceFolder}"
			},
			"isBackground": true,
			"problemMatcher": []
		},
		{
			"label": "List Connected Devices",
			"type": "shell",
			"command": "adb devices -l",
			"options": {
				"cwd": "${workspaceFolder}"
			},
			"problemMatcher": []
		},
		{
			"label": "Test Settings Module",
			"type": "shell",
			"command": "./gradlew :feature:settings:testDebugUnitTest :core:testing:testDebugUnitTest 2>&1 | grep -E \"(PASS|FAIL|ERROR|^e:|BUILD SUCCESSFUL|BUILD FAILED|> Task.*FAILED|tests.passed|tests.failed)\" | head -40"
		},
		{
			"label": "Commit review fixes",
			"type": "shell",
			"command": "git add core/testing/src/main/kotlin/com/woliveiras/palabrita/core/testing/FakeModelDownloadManager.kt feature/settings/src/main/kotlin/com/woliveiras/palabrita/feature/settings/SettingsViewModel.kt feature/settings/src/test/kotlin/com/woliveiras/palabrita/feature/settings/SettingsViewModelTest.kt feature/settings/src/test/kotlin/com/woliveiras/palabrita/feature/settings/ModelDownloadViewModelTest.kt && git commit -m \"fix(settings): use downloadManager.getModelPath for already-downloaded check\n\n- Inject ModelDownloadManager into SettingsViewModel\n- Check file presence on disk instead of comparing stored config\n- Remove redundant one-shot getStats() from loadData(); observeStats() covers it\n- Fix availableModels test assertion: isNotEmpty -> hasSize(6)\n- Add test: download progress at 50% reflected in state\n- Add test: download failure sets non-null errorMessage\""
		},
		{
			"label": "Commit formatting",
			"type": "shell",
			"command": "git add -A && git diff --cached --stat && git commit -m \"style: apply spotless formatting\""
		}
	]
}